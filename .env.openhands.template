# Copy this file to .env.openhands and fill in your key.
# Never commit .env.openhands — it contains secrets.
#
# Usage:  source .env.openhands && bash scripts/run_swebench_smoke.sh

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# Model to use — haiku is cheapest for smoke tests
# Options: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
OPENHANDS_MODEL=claude-haiku-4-5-20251001

# Number of SWE-bench Lite instances to evaluate
EVAL_N=10

# Where output lands
EVAL_OUTPUT_DIR=data/openhands_output
